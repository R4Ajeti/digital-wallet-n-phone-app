{
  "rules": {
    "appConfig": {
      ".read": true,
      ".write": false
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "sharedGuest": {
      "default": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider === 'anonymous'",
        ".write": "auth != null && auth.token.firebase.sign_in_provider === 'anonymous'",
        ".validate": "newData.hasChildren(['username', 'wallet', 'userTypeLabel', 'ticket', 'qr', 'qrOverlay', 'settings', 'createdAt', 'updatedAt'])",
        "username": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "wallet": {
          ".validate": "newData.hasChildren(['balance'])",
          "balance": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999999"
          },
          "$other": {
            ".validate": false
          }
        },
        "userTypeLabel": {
          ".validate": "newData.isString() && newData.val().length <= 160"
        },
        "ticket": {
          ".validate": "newData.hasChildren(['expiresAt', 'expiresAtText'])",
          "expiresAt": {
            ".validate": "newData.isString() && newData.val().length <= 64"
          },
          "expiresAtText": {
            ".validate": "newData.isString() && newData.val().length <= 64"
          },
          "$other": {
            ".validate": false
          }
        },
        "qr": {
          ".validate": "newData.hasChildren(['value', 'updatedAt'])",
          "value": {
            ".validate": "newData.isString() && newData.val().length <= 2048"
          },
          "updatedAt": {
            ".validate": "newData.isString() && newData.val().length <= 64"
          },
          "$other": {
            ".validate": false
          }
        },
        "qrOverlay": {
          ".validate": "newData.hasChildren(['type', 'positionX', 'positionY', 'updatedAt'])",
          "type": {
            ".validate": "newData.val() === 'default'"
          },
          "positionX": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1"
          },
          "positionY": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1"
          },
          "updatedAt": {
            ".validate": "newData.isString() && newData.val().length <= 64"
          },
          "$other": {
            ".validate": false
          }
        },
        "settings": {
          ".validate": "newData.hasChildren(['language', 'demoMode'])",
          "language": {
            ".validate": "newData.val() === 'sq'"
          },
          "demoMode": {
            ".validate": "newData.val() === true"
          },
          "$other": {
            ".validate": false
          }
        },
        "createdAt": {
          ".validate": "newData.isString() && newData.val().length <= 64"
        },
        "updatedAt": {
          ".validate": "newData.isString() && newData.val().length <= 64"
        },
        "$other": {
          ".validate": false
        }
      },
      "$other": {
        ".read": false,
        ".write": false
      }
    }
  }
}
